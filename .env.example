# ── Expo / React Native ──────────────────────────────
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Web Server (server.js) ───────────────────────────

# Anthropic — receipt scanning AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — auth + database
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key bypasses RLS — keep secret, server-side only
# Find in: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe — payments
# Find these in: Stripe dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Stripe Price IDs — create products in Stripe dashboard first
# Product: ReceiptAI Pro Monthly  → $7.99/mo  → copy the price_... ID here
STRIPE_PRICE_MONTHLY=price_...
# Product: ReceiptAI Pro Yearly   → $59.99/yr → copy the price_... ID here
STRIPE_PRICE_YEARLY=price_...

# App base URL (used for Stripe redirect after checkout)
APP_URL=http://localhost:3000
PORT=3000
